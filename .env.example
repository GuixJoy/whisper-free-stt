# STT — Local Speech-to-Text Assistant
# Copy this to .env and fill in your values:
#   cp .env.example .env

# OpenRouter API key (required for --llm-mode)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# LLM model and mode (can be overridden via CLI flags)
STT_LLM_MODEL=openai/gpt-4o-mini
STT_LLM_FALLBACK=anthropic/claude-3-5-haiku-latest
STT_LLM_MODE=cleanup
