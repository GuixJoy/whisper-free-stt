{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {"name": "stt-engine", "sidecar": true, "args": true},
        {"name": "sh", "cmd": "/bin/sh", "args": true}
      ]
    },
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {"name": "stt-engine", "sidecar": true, "args": true},
        {"name": "sh", "cmd": "/bin/sh", "args": true}
      ]
    },
    {
      "identifier": "shell:allow-stdin-write",
      "allow": [{"name": "stt-engine", "sidecar": true, "args": true}]
    }
  ]
}
